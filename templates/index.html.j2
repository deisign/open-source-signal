  font-size: 13px;
  font-weight: 800;
  letter-spacing: .04em;
  text-transform: uppercase;
  text-align: center;
  position: relative;
  z-index: 1;
}
.home-trust-strip span {
  color: var(--muted, #6d665a);
}
.home-trust-strip a {
  color: inherit;
  text-decoration: none;
}
.home-trust-strip a:hover {
  text-decoration: underline;
  text-underline-offset: .22em;
}
.footer-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16px;
  text-align: center;
}
.footer-brand {
  display: grid;
  gap: 4px;
  justify-items: center;
  max-width: 760px;
}
.footer-brand strong {
  font-weight: 850;
}
.footer-brand span {
  color: var(--muted, #6d665a);
}
footer .trust-links {
  display: flex;
  gap: 10px 16px;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  width: min(820px, 100%);
  margin: 0 auto;
}
