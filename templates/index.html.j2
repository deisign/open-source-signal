}
/* /OSS v1.1.5b trust layout */
</style>
  <script type="application/ld+json">
{{ site_schema_json | safe }}
  </script>
  {{ analytics_snippet | safe }}
</head>
<body>
  <header class="hero">
    <div class="wrap">
      <div class="hero-card">
        <div class="brand-lockup">
          <img class="brand-mark" src="{{ asset_prefix }}static/logo-mark.png" alt="Open Source Signal logo">
          <div class="brand-wording"><strong>Open Source Signal</strong><span>Сигнал відкритих джерел</span></div>
        </div>
        <div class="kicker">
          <span class="pill">OSINT editorial radar</span>
          <span class="pill">EN + UKR</span>
          <span class="pill">Daily Signal / Weekly Magazine</span>
        </div>
        <h1>{{ config['site_title_en'] }}</h1>
        <div class="ua-masthead">{{ config['site_title_uk'] }}</div>
        <div class="lead-grid">
          <section class="lead-card en">
            <h2>Signals, not noise.</h2>
            <p>{{ config['site_description_en'] }}</p>
          </section>
          <section class="lead-card uk">
            <h2>Сигнали, не шум.</h2>
            <p>{{ config['site_description_uk'] }}</p>
          </section>
        </div>
        <div class="button-row">
          <a class="button" href="{{ latest.href }}">Open latest issue</a>
          <a class="button secondary" href="archive.html">Archive</a>
          <a class="button secondary" href="{{ feed_href }}">RSS</a>
          <a class="button secondary" href="{{ config['telegram_url'] }}">Telegram</a>
        </div>

<nav class="home-trust-strip" aria-label="Trust and discovery on homepage">
  <span>Trust &amp; discovery</span>
  <a href="about.html">About</a>
  <a href="methodology.html">Methodology</a>
  <a href="ethics.html">Ethics</a>
  <a href="subscribe.html">Subscribe</a>
</nav>

      </div>
    </div>
  </header>

  <main class="wrap">
    <section class="section latest">
      <div class="section-title">
        <h2>Latest issue <span class="uk-label">/ останній випуск</span></h2>
        <a class="archive-link" href="archive.html">All issues →</a>
      </div>
      <article class="latest-card">
        <div class="latest-panel">
          <div class="issue-meta">
            <span>Issue #{{ latest.issue['issue_number'] }}</span>
            <span>{{ latest.issue['date_label_en'] }}</span>
            <span>{{ latest.issue['issue_type'] }}</span>
          </div>
          <h3>{{ latest.issue['title_en'] }}</h3>
          <div class="uk-title">{{ latest.issue['title_uk'] }}</div>
          <p>{{ latest.issue['dek_en'] }}</p>
          <a class="button" href="{{ latest.href }}">Read the issue / Читати випуск</a>
        </div>
        <div class="signal-list">
          {% for item in latest_items %}
          <div class="mini-signal theme-{{ item['theme'] }}">
            <div class="emoji">{{ item['emoji'] }}</div>
            <div>
              <div class="rubric">{{ item['rubric_en'] }} / {{ item['rubric_uk'] }}</div>
              <h4>{{ item['title_uk'] }}</h4>
              <p>{{ item['why_it_matters_uk'] }}</p>
            </div>
          </div>
          {% endfor %}
        </div>
      </article>
    </section>

    <section class="section rubrics">
      <div class="section-title">
        <h2>Rubrics <span class="uk-label">/ рубрики</span></h2>
      </div>
      <div class="rubric-grid">
        {% for rubric in latest.issue['rubric_map'] %}
        <div class="chip"><span>{{ rubric.split(' ', 1)[0] }}</span><span>{{ rubric.split(' ', 1)[1] if ' ' in rubric else rubric }}</span></div>
        {% endfor %}
      </div>
    </section>
  </main>

  <footer>
  <div class="wrap footer-inner">
    <div class="footer-brand">
      <strong>Open Source Signal / Сигнал відкритих джерел.</strong>
      <span>Ukrainian accountability OSINT journal.</span>
    </div>
    <nav class="trust-links" aria-label="Trust and discovery pages">
      {% for link in trust_nav_links %}
      <a href="{{ asset_prefix }}{{ link.href }}">{{ link.label }}</a>
      {% endfor %}
      <a href="{{ config['telegram_url'] }}">Telegram</a>
    </nav>
  </div>
</footer>
</body>
</html>
