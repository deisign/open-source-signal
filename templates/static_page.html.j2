<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ page.title }} — {{ config['site_title_en'] }}</title>
  <meta name="description" content="{{ page.meta_description }}">
  <link rel="canonical" href="{{ page_url }}">
  <meta property="og:title" content="{{ page.title }} — {{ config['site_title_en'] }}">
  <meta property="og:description" content="{{ page.meta_description }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ page_url }}">
  <meta property="og:image" content="{{ og_image_url }}">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ page.title }} — {{ config['site_title_en'] }}">
  <meta name="twitter:description" content="{{ page.meta_description }}">
  <meta name="twitter:image" content="{{ og_image_url }}">
  <link rel="alternate" type="application/rss+xml" title="Open Source Signal RSS" href="{{ asset_prefix }}{{ config['rss_path'] }}">
  <meta name="theme-color" content="#141414">
  <link rel="icon" href="{{ asset_prefix }}static/logo-mark.png" type="image/png">
  <link rel="shortcut icon" href="{{ asset_prefix }}static/favicon.ico">
  <link rel="apple-touch-icon" href="{{ asset_prefix }}static/apple-touch-icon.png">
  <link rel="manifest" href="{{ asset_prefix }}static/site.webmanifest">
  <script type="application/ld+json">{{ page_schema_json | safe }}</script>
  {{ analytics_snippet | safe }}
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Arimo:wght@500;700;800&family=Fraunces:opsz,wght@9..144,700;9..144,850&family=Inter:wght@400;600;800&family=Source+Serif+4:opsz,wght@8..60,700;8..60,850&display=swap');
    :root {
      --display-latin: Fraunces, Georgia, 'Times New Roman', serif;
      --display-cyr: 'Source Serif 4', Georgia, 'Times New Roman', serif;
      --label-font: Arimo, Arial, Helvetica, sans-serif;
      --paper: #F2EDDD;
      --paper-2: #FFF9EA;
      --ink: #141414;
      --muted: #6d665a;
      --line: rgba(20,20,20,.16);
      --accent: #245c73;
      --shadow: 0 24px 70px rgba(20,20,20,.12);
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      color: var(--ink);
      background:
        radial-gradient(circle at 14% 18%, rgba(165,74,44,.16), transparent 26rem),
        radial-gradient(circle at 84% 12%, rgba(36,92,115,.16), transparent 24rem),
        linear-gradient(135deg, #f7f0df, #ece1c6 58%, #d9cfb7);
      font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      font-size: 18px;
      line-height: 1.58;
    }
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      opacity: .22;
      background-image: linear-gradient(rgba(20,20,20,.035) 1px, transparent 1px), linear-gradient(90deg, rgba(20,20,20,.035) 1px, transparent 1px);
      background-size: 28px 28px;
      mask-image: linear-gradient(to bottom, #000, transparent 85%);
    }
    a { color: inherit; text-decoration-thickness: .1em; text-underline-offset: .18em; }
    .wrap { width: min(980px, calc(100% - 36px)); margin: 0 auto; }
    header { padding: 56px 0 24px; }
    .topline { display: flex; justify-content: space-between; gap: 18px; align-items: center; flex-wrap: wrap; font-family: var(--label-font); font-size: 13px; font-weight: 800; letter-spacing: .07em; text-transform: uppercase; color: var(--muted); }
    .topline a { text-decoration: none; }
    .brand-row { display:flex; gap:14px; align-items:center; margin-top: 28px; }
    .brand-row img { width:60px; height:60px; border-radius:15px; box-shadow: 0 10px 24px rgba(20,20,20,.12); }
    .brand-copy { display:flex; flex-direction:column; }
    .brand-copy strong { font-family: var(--label-font); font-size: 14px; letter-spacing: .08em; text-transform: uppercase; }
    .brand-copy span { font-family: var(--label-font); font-size: 17px; color: #3b362f; font-weight: 700; letter-spacing: .015em; }
    .eyebrow { margin-top: 54px; font-family: var(--label-font); color: var(--muted); text-transform: uppercase; letter-spacing: .08em; font-size: 13px; font-weight: 800; }
    h1 { margin: 16px 0 8px; font-family: var(--display-latin); font-size: clamp(58px, 9vw, 118px); line-height: .84; letter-spacing: -.07em; }
    .ua-title { font-family: var(--display-cyr); font-size: clamp(34px, 5.4vw, 72px); letter-spacing: -.04em; line-height: .95; font-weight: 850; color: #302b25; margin: 0 0 26px; }
    .lead { max-width: 820px; font-size: clamp(22px, 2.7vw, 34px); line-height: 1.18; letter-spacing: -.035em; font-weight: 800; color: #25211d; }
    main { padding: 22px 0 80px; }
    .panel { border: 1px solid var(--line); background: rgba(255,249,234,.74); border-radius: 32px; padding: clamp(24px, 4vw, 44px); box-shadow: var(--shadow); margin: 22px 0; }
    section + section { margin-top: 28px; }
    h2 { font-family: var(--label-font); font-size: 16px; letter-spacing: .08em; text-transform: uppercase; margin: 0 0 16px; color: var(--accent); }
    p { margin: 0 0 18px; max-width: 78ch; }
    ul { margin: 0 0 20px 1.15rem; padding: 0; }
    li { margin: 0 0 8px; }
    .cta { display:flex; gap:12px; flex-wrap:wrap; margin-top: 28px; }
    .cta a { display:inline-flex; align-items:center; border:1px solid var(--line); border-radius:999px; background:#141414; color:#fff9ea; padding:10px 14px; text-decoration:none; font-family:var(--label-font); font-size:13px; font-weight:800; letter-spacing:.04em; text-transform:uppercase; }
    footer { border-top: 1px solid var(--line); padding: 28px 0 42px; color: var(--muted); font-family: var(--label-font); font-size: 13px; font-weight: 700; }
    .footer-inner, .footer-links, .trust-links { display:flex; gap:16px; align-items:center; justify-content:space-between; flex-wrap:wrap; }
    .footer-links a, .trust-links a { color: inherit; text-decoration: none; font-weight: 800; }
    .trust-links { justify-content:flex-start; margin-top: 14px; }
    @media (max-width: 680px) { h1 { font-size: clamp(48px, 18vw, 78px); } .panel { border-radius: 24px; } }
  .trust-links {
  display: flex;
  gap: 10px 16px;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  width: 100%;
  margin: 18px auto 0;
  text-align: center;
  font-family: var(--label-font, Arimo, Arial, Helvetica, sans-serif);
  font-size: 13px;
  font-weight: 800;
  letter-spacing: .04em;
  text-transform: uppercase;
}
.trust-links a {
  color: inherit;
  text-decoration: none;
}
.trust-links a:hover {
  text-decoration: underline;
  text-underline-offset: .22em;
}
footer .trust-links {
  justify-content: center;
}
footer .footer-inner {
  justify-content: center;
  text-align: center;
}


/* OSS v1.1.5b trust layout */
.home-trust-strip {
  display: flex;
  gap: 10px 14px;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  width: min(760px, 100%);
  margin: 22px auto 0;
  padding: 11px 14px;
  border: 1px solid var(--line, rgba(20,20,20,.16));
  border-radius: 999px;
  background: rgba(255,249,234,.62);
  color: var(--muted, #6d665a);
  font-family: var(--label-font, JetBrains Mono, ui-monospace, SFMono-Regular, Menlo, Consolas, monospace);
  font-size: 13px;
  font-weight: 800;
  letter-spacing: .04em;
  text-transform: uppercase;
  text-align: center;
  position: relative;
  z-index: 1;
}
.home-trust-strip span {
  color: var(--muted, #6d665a);
}
.home-trust-strip a {
  color: inherit;
  text-decoration: none;
}
.home-trust-strip a:hover {
  text-decoration: underline;
  text-underline-offset: .22em;
}
.footer-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16px;
  text-align: center;
}
.footer-brand {
  display: grid;
  gap: 4px;
  justify-items: center;
  max-width: 760px;
}
.footer-brand strong {
  font-weight: 850;
}
.footer-brand span {
  color: var(--muted, #6d665a);
}
footer .trust-links {
  display: flex;
  gap: 10px 16px;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  width: min(820px, 100%);
  margin: 0 auto;
}
footer .trust-links a {
  color: inherit;
  text-decoration: none;
  font-weight: 800;
}
footer .trust-links a:hover {
  text-decoration: underline;
  text-underline-offset: .22em;
}
/* /OSS v1.1.5b trust layout */
</style>
</head>
<body>
  <header class="wrap">
    <div class="topline">
      <a href="{{ asset_prefix }}index.html">← Daily Signal</a>
      <nav aria-label="Primary navigation">
        <a href="{{ asset_prefix }}archive.html">Archive</a> ·
        <a href="{{ asset_prefix }}methodology.html">Methodology</a> ·
        <a href="{{ asset_prefix }}ethics.html">Ethics</a> ·
        <a href="{{ asset_prefix }}subscribe.html">Subscribe</a>
      </nav>
    </div>
    <div class="brand-row">
      <img class="brand-mark" src="{{ asset_prefix }}static/logo-mark.png" alt="Open Source Signal mark">
      <div class="brand-copy">
        <strong>{{ config['site_title_en'] }}</strong>
        <span>{{ config['site_title_uk'] }}</span>
      </div>
    </div>
    <div class="eyebrow">{{ page.eyebrow }}</div>
    <h1>{{ page.title }}</h1>
    <p class="ua-title">{{ page.title_uk }}</p>
    <p class="lead">{{ page.lead }}</p>
  </header>
  <main class="wrap">
    <article class="panel">
      {% for section in page.sections %}
      <section>
        <h2>{{ section.heading }}</h2>
        {% for block in section.blocks %}
          {% if block.type == 'p' %}
          <p>{{ block.text }}</p>
          {% elif block.type == 'ul' %}
          <ul>
            {% for item in block['items'] %}
            <li>{{ item }}</li>
            {% endfor %}
          </ul>
          {% endif %}
        {% endfor %}
      </section>
      {% endfor %}
      {% if page.cta_links %}
      <div class="cta">
        {% for link in page.cta_links %}
        <a href="{{ link.href }}">{{ link.label }}</a>
        {% endfor %}
      </div>
      {% endif %}
    </article>
  </main>
  <footer>
  <div class="wrap footer-inner">
    <div class="footer-brand">
      <strong>Open Source Signal / Сигнал відкритих джерел.</strong>
      <span>Ukrainian accountability OSINT journal.</span>
    </div>
    <nav class="trust-links" aria-label="Trust and discovery pages">
      {% for link in trust_nav_links %}
      <a href="{{ asset_prefix }}{{ link.href }}">{{ link.label }}</a>
      {% endfor %}
      <a href="{{ config['telegram_url'] }}">Telegram</a>
    </nav>
  </div>
</footer>
</body>
</html>
