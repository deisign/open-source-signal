<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Weekly Magazine — {{ config["site_title_en"] }}</title>
  <meta name="description" content="Weekly Magazine archive for Open Source Signal.">
  <link rel="canonical" href="{{ page_url }}">
  <meta property="og:type" content="website">
  <meta property="og:title" content="Open Source Signal Weekly Magazine">
  <meta property="og:description" content="Sunday editorial synthesis for Ukrainian accountability OSINT.">
  <meta property="og:url" content="{{ page_url }}">
  <meta property="og:image" content="{{ og_image_url }}">
  {{ analytics_snippet | safe }}
  <link rel="icon" href="{{ asset_prefix }}static/logo-mark.png" type="image/png">
  <link rel="shortcut icon" href="{{ asset_prefix }}static/favicon.ico">
  <link rel="apple-touch-icon" href="{{ asset_prefix }}static/apple-touch-icon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Arimo:wght@500;600;700&family=Fraunces:opsz,wght,SOFT,WONK@9..144,600..900,50..100,0..1&family=Inter:wght@400;500;650;800;900&family=JetBrains+Mono:wght@400;600;800&family=Source+Serif+4:opsz,wght@8..60,600..900&display=swap" rel="stylesheet">
  <style>
:root { --display-latin: Fraunces, Georgia, serif; --display-cyr: "Source Serif 4", Georgia, serif; --label-font: Arimo, Arial, sans-serif; --paper:#F2EDDD; --paper-2:#FFF9EA; --ink:#141414; --muted:#6d665a; --line:rgba(20,20,20,.16); --signal:#D6422B; --shadow:0 24px 70px rgba(20,20,20,.12); }
* { box-sizing: border-box; }
body { margin:0; color:var(--ink); background: radial-gradient(circle at 12% 6%, rgba(214,66,43,.18), transparent 27rem), linear-gradient(135deg,#f7f0df,#ece1c6 58%,#d9cfb7); font-family: Inter, system-ui, sans-serif; font-size:18px; line-height:1.5; }
a { color: inherit; text-underline-offset:.2em; }
.wrap { width:min(1040px, calc(100% - 36px)); margin:0 auto; }
.hero { padding:56px 0 34px; }
.hero-card { border:1px solid var(--line); background:rgba(255,249,234,.72); border-radius:42px; padding:clamp(26px,5vw,64px); box-shadow:var(--shadow); }
.brand-lockup { display:flex; gap:16px; align-items:center; margin-bottom:34px; }
.brand-lockup img { width:64px; height:64px; border-radius:18px; box-shadow:0 10px 24px rgba(20,20,20,.12); }
.brand-copy { display:flex; flex-direction:column; }
.brand-copy strong { font-family:var(--label-font); font-size:15px; letter-spacing:.08em; text-transform:uppercase; }
.brand-copy span { font-family:var(--label-font); font-size:18px; color:#3b362f; font-weight:700; }
.eyebrow { display:inline-flex; margin-bottom:14px; color:var(--muted); font-family:JetBrains Mono, monospace; font-size:13px; font-weight:800; letter-spacing:.08em; text-transform:uppercase; }
h1 { margin:0 0 14px; font-family:var(--display-latin); font-size:clamp(52px,9vw,116px); line-height:.88; letter-spacing:-.07em; }
.ua { margin:0 0 20px; font-family:var(--display-cyr); font-size:clamp(34px,6vw,74px); line-height:.94; letter-spacing:-.045em; }
.lead { max-width:780px; font-size:22px; color:#3d382f; }
.latest-card, .issue-row { border:1px solid var(--line); background:rgba(255,249,234,.72); border-radius:28px; padding:24px; box-shadow:0 12px 38px rgba(20,20,20,.06); }
.latest-card { margin:28px 0; }
.latest-card h2, .archive-title { margin:0 0 12px; font-family:var(--display-latin); font-size:42px; line-height:.96; letter-spacing:-.045em; }
.actions { display:flex; gap:10px 14px; flex-wrap:wrap; margin-top:18px; }
.actions a, .trust-links a { display:inline-flex; border:1px solid rgba(20,20,20,.2); background:rgba(255,255,255,.45); border-radius:999px; padding:10px 14px; text-decoration:none; font-weight:800; }
.issue-list { display:grid; gap:16px; margin:28px 0 70px; }
.issue-row { display:grid; grid-template-columns: 150px 1fr; gap:18px; align-items:start; }
.issue-meta { color:var(--muted); font-family:JetBrains Mono, monospace; font-size:13px; text-transform:uppercase; letter-spacing:.06em; }
.issue-row h3 { margin:0 0 8px; font-family:var(--display-latin); font-size:32px; line-height:1; letter-spacing:-.04em; }
footer { padding:44px 0 80px; text-align:center; color:#4f493f; }
.trust-links { display:flex; justify-content:center; gap:10px 14px; flex-wrap:wrap; margin-top:18px; font-family:var(--label-font); font-size:13px; text-transform:uppercase; letter-spacing:.04em; }
@media (max-width:760px){ .issue-row { grid-template-columns:1fr; } }
  </style>
</head>
<body>
  <header class="hero">
    <div class="wrap hero-card">
      <div class="brand-lockup">
        <img src="{{ asset_prefix }}static/logo-mark.png" alt="Open Source Signal logo">
        <div class="brand-copy"><strong>Open Source Signal</strong><span>Сигнал відкритих джерел</span></div>
      </div>
      <div class="eyebrow">Weekly Magazine archive</div>
      <h1>Open Source Signal Weekly</h1>
      <p class="ua">Тижневий сигнал відкритих джерел</p>
      <p class="lead">Sunday editorial synthesis of the strongest OSINT signals of the week: Ukrainian accountability, verification, tools, datasets, tradecraft, and source-risk notes.</p>
      <div class="actions"><a href="../index.html">Daily Signal</a><a href="../archive.html">Archive</a><a href="../feed.xml">RSS</a><a href="{{ config['telegram_url'] }}">Telegram</a></div>
    </div>
  </header>
  <main class="wrap">
    {% if latest %}
    <section class="latest-card">
      <div class="eyebrow">Latest weekly</div>
      <h2>{{ latest["issue_number"] }} · {{ latest["week_label_en"] }}</h2>
      <p>{{ latest["dek_en"] }}</p>
      <div class="actions"><a href="{{ latest['output_name'] }}">Read latest weekly</a></div>
    </section>
    {% endif %}
    <h2 class="archive-title">All weekly issues</h2>
    <section class="issue-list" aria-label="Weekly issues">
      {% for issue in weekly_issues %}
      <article class="issue-row">
        <div class="issue-meta">{{ issue["issue_number"] }}<br>{{ issue["week_label_en"] }}</div>
        <div><h3><a href="{{ issue['output_name'] }}">{{ issue["title_en"] }}</a></h3><p>{{ issue["dek_en"] }}</p></div>
      </article>
      {% endfor %}
    </section>
  </main>
  <footer>
    <div class="wrap">
      <strong>Open Source Signal / Сигнал відкритих джерел.</strong><br>
      <span>Ukrainian accountability OSINT journal.</span>
      <nav class="trust-links" aria-label="Trust and discovery pages">{% for link in trust_nav_links %}<a href="../{{ link.href }}">{{ link.label }}</a>{% endfor %}<a href="{{ config['telegram_url'] }}">Telegram</a></nav>
    </div>
  </footer>
</body>
</html>
