<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Weekly Magazine — {{ config["site_title_en"] }}</title>
  <meta name="description" content="Weekly Magazine archive for Open Source Signal.">
  <link rel="canonical" href="{{ page_url }}">
  <meta property="og:type" content="website">
  <meta property="og:title" content="Open Source Signal Weekly">
  <meta property="og:description" content="Sunday editorial synthesis of the strongest OSINT signals of the week.">
  <meta property="og:url" content="{{ page_url }}">
  <meta property="og:image" content="{{ og_image_url }}">
  {{ analytics_snippet | safe }}
  <link rel="icon" href="{{ asset_prefix }}static/logo-mark.png" type="image/png">
  <link rel="shortcut icon" href="{{ asset_prefix }}static/favicon.ico">
  <link rel="apple-touch-icon" href="{{ asset_prefix }}static/apple-touch-icon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Arimo:wght@500;600;700&family=Fraunces:opsz,wght,SOFT,WONK@9..144,600..900,50..100,0..1&family=Inter:wght@400;500;650;800;900&family=JetBrains+Mono:wght@400;600;800&family=Source+Serif+4:opsz,wght@8..60,600..900&display=swap" rel="stylesheet">
  <style>
:root {
  --display-latin: Fraunces, Georgia, serif;
  --display-cyr: "Source Serif 4", Georgia, serif;
  --label-font: Arimo, Arial, sans-serif;
  --paper: #F2EDDD;
  --paper-2: #FFF9EA;
  --ink: #141414;
  --muted: #6d665a;
  --line: rgba(20,20,20,.16);
  --signal: #D6422B;
  --shadow: 0 24px 70px rgba(20,20,20,.10);
}
* { box-sizing: border-box; }
body {
  margin: 0;
  color: var(--ink);
  background:
    radial-gradient(circle at 10% 5%, rgba(214,66,43,.14), transparent 27rem),
    linear-gradient(135deg, #f7f0df, #ece1c6 58%, #d9cfb7);
  font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-size: 18px;
  line-height: 1.5;
}
a { color: inherit; }
.wrap { width: min(1080px, calc(100% - 36px)); margin: 0 auto; }
.header { padding: 44px 0 28px; }
.brand { display: flex; gap: 14px; align-items: center; margin-bottom: 34px; }
.brand img { width: 56px; height: 56px; border-radius: 16px; box-shadow: 0 10px 24px rgba(20,20,20,.12); }
.brand strong { display: block; font-family: var(--label-font); font-size: 14px; letter-spacing: .08em; text-transform: uppercase; }
.brand span { display: block; color: #3b362f; font-weight: 700; }
.hero {
  border: 1px solid var(--line);
  background: rgba(255,249,234,.72);
  border-radius: 36px;
  padding: clamp(28px, 5vw, 56px);
  box-shadow: var(--shadow);
}
.kicker { color: var(--muted); font-family: JetBrains Mono, monospace; font-size: 13px; font-weight: 800; letter-spacing: .09em; text-transform: uppercase; }
h1 { margin: 14px 0 6px; font-family: var(--display-latin); font-size: clamp(54px, 9vw, 112px); line-height: .88; letter-spacing: -.065em; }
.ua-title { margin: 0; font-family: var(--display-cyr); font-size: clamp(34px, 5vw, 70px); line-height: .92; letter-spacing: -.04em; color: #2f2b25; }
.lead { max-width: 760px; margin: 22px 0 0; font-size: 21px; color: #3d382f; }
.nav { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 26px; }
.nav a, .issue-card a, .trust-links a {
  display: inline-flex;
  border: 1px solid rgba(20,20,20,.2);
  background: rgba(255,255,255,.45);
  border-radius: 999px;
  padding: 10px 14px;
  text-decoration: none;
  font-size: 14px;
  font-weight: 800;
}
.issue-list { display: grid; gap: 18px; margin: 34px 0 70px; }
.issue-card {
  border: 1px solid var(--line);
  border-radius: 28px;
  background: rgba(255,249,234,.68);
  padding: 24px;
  box-shadow: 0 12px 36px rgba(20,20,20,.06);
}
.issue-meta { color: var(--signal); font-family: JetBrains Mono, monospace; font-size: 13px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; }
.issue-card h2 { margin: 10px 0 10px; font-family: var(--display-latin); font-size: clamp(30px, 4.5vw, 54px); line-height: .94; letter-spacing: -.045em; }
.issue-card p { max-width: 780px; color: #3d382f; }
.footer { padding: 0 0 70px; text-align: center; color: #4f493f; }
.trust-links { display: flex; justify-content: center; gap: 10px 14px; flex-wrap: wrap; margin-top: 16px; }
@media (max-width: 760px) { body { font-size: 16px; } }

    /* OSS global heading scale v2026-06-11 */
    h1,
    .hero h1,
    .hero-card h1,
    .page-title,
    .hero-title,
    .masthead-title {
      font-size: clamp(38px, 6.8vw, 92px) !important;
      line-height: .94 !important;
      letter-spacing: -.052em !important;
      overflow-wrap: anywhere;
      hyphens: auto;
      text-wrap: balance;
    }

    .ua-masthead,
    .hero-title-uk,
    .masthead-uk,
    .page-title-uk {
      font-size: clamp(32px, 5vw, 64px) !important;
      line-height: .98 !important;
      letter-spacing: -.028em !important;
      overflow-wrap: anywhere;
      hyphens: auto;
      text-wrap: balance;
    }

    h2,
    .section-title,
    .card-title,
    .issue-title,
    .weekly-title,
    .tool-title {
      font-size: clamp(26px, 3.2vw, 44px) !important;
      line-height: 1.06 !important;
      letter-spacing: -.035em !important;
      overflow-wrap: anywhere;
      hyphens: auto;
      text-wrap: balance;
    }

    .brief-card h2,
    .rubric-map h2,
    .archive-card h2,
    .static-page h2 {
      font-size: clamp(25px, 2.8vw, 38px) !important;
      line-height: 1.08 !important;
      letter-spacing: -.03em !important;
    }

    .signal-card,
    .weekly-card,
    .tool-card,
    .lang-panel,
    .source-line,
    .source-pill,
    .tags,
    .rubric-chip {
      min-width: 0;
      max-width: 100%;
      overflow-wrap: anywhere;
    }

  </style>
</head>
<body>
  <header class="header">
    <div class="wrap">
      <div class="brand">
        <img src="{{ asset_prefix }}static/logo-mark.png" alt="Open Source Signal logo">
        <div>
          <strong>Open Source Signal</strong>
          <span>Сигнал відкритих джерел</span>
        </div>
      </div>

      <section class="hero">
        <div class="kicker">Weekly Magazine archive</div>
        <h1>Open Source Signal Weekly</h1>
        <p class="ua-title">Тижневий сигнал відкритих джерел</p>
        <p class="lead">
          Sunday editorial synthesis of the strongest OSINT signals of the week:
          Ukrainian accountability, verification, tools, datasets, tradecraft, and source-risk notes.
        </p>
        <nav class="nav" aria-label="Weekly archive navigation">
          <a href="../index.html">Daily Signal</a>
          <a href="../archive.html">Daily archive</a>
          <a href="../feed.xml">RSS</a>
          <a href="{{ config["telegram_url"] }}">Telegram</a>
        </nav>
      </section>
    </div>
  </header>

  <main class="wrap">
    <section class="issue-list" aria-label="Weekly issues">
      {% if latest %}
      <article class="issue-card">
        <div class="issue-meta">Latest weekly · {{ latest["issue_number"] }} · {{ latest["week_label_en"] }}</div>
        <h2><a href="{{ latest["output_name"] }}">{{ latest["title_en"] }}</a></h2>
        <p>{{ latest["dek_en"] }}</p>
        <a href="{{ latest["output_name"] }}">Read latest weekly</a>
      </article>
      {% endif %}

      {% for issue in weekly_issues %}
      {% if not latest or issue["output_name"] != latest["output_name"] %}
      <article class="issue-card">
        <div class="issue-meta">{{ issue["issue_number"] }} · {{ issue["week_label_en"] }}</div>
        <h2><a href="{{ issue["output_name"] }}">{{ issue["title_en"] }}</a></h2>
        <p>{{ issue["dek_en"] }}</p>
        <a href="{{ issue["output_name"] }}">Read issue</a>
      </article>
      {% endif %}
      {% endfor %}
    </section>
  </main>

  <footer class="footer">
    <div class="wrap">
      <strong>Open Source Signal / Сигнал відкритих джерел.</strong><br>
      <span>Ukrainian accountability OSINT journal.</span>
      <nav class="trust-links" aria-label="Trust and discovery pages">
        {% for link in trust_nav_links %}<a href="../{{ link.href }}">{{ link.label }}</a>{% endfor %}
        <a href="{{ config["telegram_url"] }}">Telegram</a>
      </nav>
    </div>
  </footer>
</body>
</html>
