<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ weekly.title_en }} #{{ weekly.issue_number }} / {{ weekly.title_uk }}</title>
  <meta name="description" content="{{ weekly.dek_en }}">
  <meta property="og:title" content="{{ weekly.title_en }} #{{ weekly.issue_number }}">
  <meta property="og:description" content="{{ weekly.dek_en }}">
  <meta property="og:type" content="article">
  <meta property="og:image" content="{{ og_image_url }}">
  <link rel="icon" href="{{ asset_prefix }}static/logo-mark.png">
  <style>
    :root { --paper: #fbf4df; --ink: #151515; --muted: #716b5f; --line: rgba(21, 21, 21, .18); --accent: #b4472e; }
    body { margin: 0; background: var(--paper); color: var(--ink); font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; line-height: 1.6; }
    .page { width: min(1080px, calc(100% - 32px)); margin: 0 auto; padding: 38px 0 54px; }
    header, .weekly-section, .reading-list, footer { border-top: 1px solid var(--line); padding-top: 24px; margin-top: 28px; }
    .eyebrow, .meta, .tags { color: var(--muted); font-size: 13px; font-weight: 800; letter-spacing: .05em; text-transform: uppercase; }
    h1, h2, h3 { line-height: 1.1; margin: 0 0 14px; }
    h1 { font-size: clamp(40px, 7vw, 76px); letter-spacing: -.04em; }
    h2 { font-size: clamp(28px, 4vw, 44px); letter-spacing: -.03em; }
    h3 { font-size: 22px; }
    a { color: inherit; text-decoration-color: rgba(180, 71, 46, .45); text-underline-offset: .18em; }
    .dek { max-width: 780px; font-size: 20px; color: #2a2926; }
    .note-grid, .section-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; }
    .weekly-card { border: 1px solid var(--line); border-radius: 22px; padding: 20px; background: rgba(255, 255, 255, .28); margin-top: 16px; }
    .source { color: var(--muted); font-size: 14px; }
    .tags span { display: inline-block; margin: 8px 8px 0 0; border: 1px solid var(--line); border-radius: 999px; padding: 3px 8px; color: var(--muted); }
    footer nav { display: flex; flex-wrap: wrap; gap: 10px 16px; justify-content: center; text-align: center; }
  </style>
</head>
<body>
  <main class="page">
    <p class="eyebrow">Open Source Signal / Weekly Magazine</p>
    <header>
      <p class="meta">Issue #{{ weekly.issue_number }} · {{ weekly.date_label_en }} · {{ weekly.issue_type }} · {{ weekly.language_label }}</p>
      <h1>{{ weekly.title_en }}</h1>
      <h2>{{ weekly.title_uk }}</h2>
      <p class="dek">{{ weekly.dek_en }}</p>
      <p class="dek">{{ weekly.dek_uk }}</p>
    </header>

    <section class="weekly-section editorial-note" aria-labelledby="editorial-note">
      <h2 id="editorial-note">Editorial note / Редакційна нотатка</h2>
      <div class="note-grid"><p>{{ weekly.editorial_note_en }}</p><p>{{ weekly.editorial_note_uk }}</p></div>
    </section>

    {% for section in weekly.sections %}
    <section class="weekly-section" aria-labelledby="section-{{ section.key }}">
      <p class="eyebrow">{{ section.key }}</p>
      <h2 id="section-{{ section.key }}">{{ section.heading_en }} / {{ section.heading_uk }}</h2>
      <div class="section-grid"><p>{{ section.summary_en }}</p><p>{{ section.summary_uk }}</p></div>
      {% for item in section['items'] %}
      <article class="weekly-card">
        <h3>{{ item.title_en }}</h3>
        <h3>{{ item.title_uk }}</h3>
        <p class="source">Source: <a href="{{ item.source_url }}">{{ item.source_name }}</a> · {{ item.source_date_label_en }}</p>
        <h4>Why it matters</h4><p>{{ item.why_it_matters_en }}</p>
        <h4>Чому це важливо</h4><p>{{ item.why_it_matters_uk }}</p>
        <h4>Limits / Обмеження</h4><p>{{ item.limits_en }}</p><p>{{ item.limits_uk }}</p>
        <p class="tags">{% for tag in item.tags %}<span>{{ tag }}</span>{% endfor %}</p>
      </article>
      {% endfor %}
    </section>
    {% endfor %}

    <section class="reading-list" aria-labelledby="reading-list">
      <h2 id="reading-list">Reading List / Список читання</h2>
      {% for item in weekly.reading_list %}
      <article class="weekly-card">
        <h3><a href="{{ item.source_url }}">{{ item.title }}</a></h3>
        <p class="source">{{ item.source_name }}</p>
        <p>{{ item.note_en }}</p><p>{{ item.note_uk }}</p>
      </article>
      {% endfor %}
    </section>

    <footer>
      <p class="meta">Open Source Signal / Сигнал відкритих джерел</p>
      <nav aria-label="Footer navigation">
        <a href="../index.html">Daily Signal</a><a href="../archive.html">Archive</a><a href="../about.html">About</a><a href="../methodology.html">Methodology</a><a href="../ethics.html">Ethics</a><a href="../contact.html">Contact</a><a href="../subscribe.html">Subscribe</a>
      </nav>
    </footer>
  </main>
</body>
</html>
