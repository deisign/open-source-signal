<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ page.title }} — {{ config['site_title_en'] }}</title>
  <meta name="description" content="{{ page.meta_description }}">
  <meta name="robots" content="noindex">
  <link rel="canonical" href="{{ page_url }}">
  <meta property="og:title" content="{{ page.title }} — {{ config['site_title_en'] }}">
  <meta property="og:description" content="{{ page.meta_description }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ page_url }}">
  <meta property="og:image" content="{{ og_image_url }}">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="alternate" type="application/rss+xml" title="Open Source Signal RSS" href="{{ asset_prefix }}{{ config['rss_path'] }}">
  <link rel="icon" href="{{ asset_prefix }}static/logo-mark.png" type="image/png">
  <link rel="shortcut icon" href="{{ asset_prefix }}static/favicon.ico">
  {{ analytics_snippet | safe }}
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Arimo:wght@700;800&family=Fraunces:opsz,wght@9..144,850&family=Inter:wght@400;600;800&family=Source+Serif+4:opsz,wght@8..60,850&display=swap');
    :root { --display-latin: Fraunces, Georgia, serif; --display-cyr:'Source Serif 4', Georgia, serif; --label-font: Arimo, Arial, sans-serif; --paper:#F2EDDD; --ink:#141414; --muted:#6d665a; --line:rgba(20,20,20,.16); }
    * { box-sizing: border-box; }
    body { min-height:100vh; margin:0; color:var(--ink); background: radial-gradient(circle at 18% 18%, rgba(165,74,44,.18), transparent 24rem), radial-gradient(circle at 86% 12%, rgba(36,92,115,.18), transparent 24rem), linear-gradient(135deg,#f7f0df,#ece1c6 58%,#d9cfb7); font-family:Inter, system-ui, sans-serif; font-size:18px; line-height:1.55; display:flex; align-items:center; }
    .wrap { width:min(900px, calc(100% - 36px)); margin:0 auto; padding:56px 0; }
    .panel { border:1px solid var(--line); background:rgba(255,249,234,.78); border-radius:34px; padding:clamp(28px, 6vw, 58px); box-shadow:0 24px 70px rgba(20,20,20,.12); }
    .eyebrow, nav { font-family:var(--label-font); font-size:13px; font-weight:800; letter-spacing:.08em; text-transform:uppercase; color:var(--muted); }
    h1 { margin:18px 0 8px; font-family:var(--display-latin); font-size:clamp(64px, 13vw, 150px); line-height:.82; letter-spacing:-.075em; }
    .ua-title { margin:0 0 24px; font-family:var(--display-cyr); font-size:clamp(34px, 5vw, 68px); line-height:.95; letter-spacing:-.04em; font-weight:850; }
    p { max-width:72ch; }
    .cta { display:flex; flex-wrap:wrap; gap:12px; margin-top:30px; }
    a { color:inherit; text-decoration-thickness:.1em; text-underline-offset:.18em; }
    .cta a { background:#141414; color:#fff9ea; border-radius:999px; padding:10px 14px; text-decoration:none; font-family:var(--label-font); font-size:13px; font-weight:800; letter-spacing:.04em; text-transform:uppercase; }
    .trust-links {
  display: flex;
  gap: 10px 16px;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  width: 100%;
  margin: 18px auto 0;
  text-align: center;
  font-family: var(--label-font, Arimo, Arial, Helvetica, sans-serif);
  font-size: 13px;
  font-weight: 800;
  letter-spacing: .04em;
  text-transform: uppercase;
}
.trust-links a {
  color: inherit;
  text-decoration: none;
}
.trust-links a:hover {
  text-decoration: underline;
  text-underline-offset: .22em;
}
footer .trust-links {
  justify-content: center;
}
footer .footer-inner {
  justify-content: center;
  text-align: center;
}


/* OSS v1.1.5b trust layout */
.home-trust-strip {
  display: flex;
  gap: 10px 14px;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  width: min(760px, 100%);
  margin: 22px auto 0;
  padding: 11px 14px;
  border: 1px solid var(--line, rgba(20,20,20,.16));
  border-radius: 999px;
  background: rgba(255,249,234,.62);
  color: var(--muted, #6d665a);
  font-family: var(--label-font, JetBrains Mono, ui-monospace, SFMono-Regular, Menlo, Consolas, monospace);
  font-size: 13px;
  font-weight: 800;
  letter-spacing: .04em;
  text-transform: uppercase;
  text-align: center;
  position: relative;
  z-index: 1;
}
.home-trust-strip span {
  color: var(--muted, #6d665a);
}
.home-trust-strip a {
  color: inherit;
  text-decoration: none;
}
.home-trust-strip a:hover {
  text-decoration: underline;
  text-underline-offset: .22em;
}
.footer-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16px;
  text-align: center;
}
.footer-brand {
  display: grid;
  gap: 4px;
  justify-items: center;
  max-width: 760px;
}
.footer-brand strong {
  font-weight: 850;
}
.footer-brand span {
  color: var(--muted, #6d665a);
}
footer .trust-links {
  display: flex;
  gap: 10px 16px;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  width: min(820px, 100%);
  margin: 0 auto;
}
footer .trust-links a {
  color: inherit;
  text-decoration: none;
  font-weight: 800;
}
footer .trust-links a:hover {
  text-decoration: underline;
  text-underline-offset: .22em;
}
/* /OSS v1.1.5b trust layout */

    /* OSS global heading scale v2026-06-11 */
    h1,
    .hero h1,
    .hero-card h1,
    .page-title,
    .hero-title,
    .masthead-title {
      font-size: clamp(38px, 6.8vw, 92px) !important;
      line-height: .94 !important;
      letter-spacing: -.052em !important;
      overflow-wrap: anywhere;
      hyphens: auto;
      text-wrap: balance;
    }

    .ua-masthead,
    .hero-title-uk,
    .masthead-uk,
    .page-title-uk {
      font-size: clamp(32px, 5vw, 64px) !important;
      line-height: .98 !important;
      letter-spacing: -.028em !important;
      overflow-wrap: anywhere;
      hyphens: auto;
      text-wrap: balance;
    }

    h2,
    .section-title,
    .card-title,
    .issue-title,
    .weekly-title,
    .tool-title {
      font-size: clamp(26px, 3.2vw, 44px) !important;
      line-height: 1.06 !important;
      letter-spacing: -.035em !important;
      overflow-wrap: anywhere;
      hyphens: auto;
      text-wrap: balance;
    }

    .brief-card h2,
    .rubric-map h2,
    .archive-card h2,
    .static-page h2 {
      font-size: clamp(25px, 2.8vw, 38px) !important;
      line-height: 1.08 !important;
      letter-spacing: -.03em !important;
    }

    .signal-card,
    .weekly-card,
    .tool-card,
    .lang-panel,
    .source-line,
    .source-pill,
    .tags,
    .rubric-chip {
      min-width: 0;
      max-width: 100%;
      overflow-wrap: anywhere;
    }

  </style>
</head>
<body>
  <main class="wrap">
    <article class="panel">
      <div class="eyebrow">{{ page.eyebrow }}</div>
      <h1>{{ page.title }}</h1>
      <p class="ua-title">{{ page.title_uk }}</p>
      <p><strong>{{ page.lead }}</strong></p>
      <p>{{ page.body_en }}</p>
      <p>{{ page.body_uk }}</p>
      <div class="cta">
        {% for link in page.cta_links %}
        <a href="{{ link.href }}">{{ link.label }}</a>
        {% endfor %}
      </div>
      <nav class="trust-links" aria-label="Trust and discovery pages">
        {% for link in trust_nav_links %}
        <a href="{{ asset_prefix }}{{ link.href }}">{{ link.label }}</a>
        {% endfor %}
      </nav>
    </article>
  </main>
<footer>
  <div class="wrap footer-inner">
    <div class="footer-brand">
      <strong>Open Source Signal / Сигнал відкритих джерел.</strong>
      <span>Ukrainian accountability OSINT journal.</span>
    </div>
    <nav class="trust-links" aria-label="Trust and discovery pages">
      {% for link in trust_nav_links %}
      <a href="{{ asset_prefix }}{{ link.href }}">{{ link.label }}</a>
      {% endfor %}
      <a href="{{ config['telegram_url'] }}">Telegram</a>
    </nav>
  </div>
</footer>

</body>
</html>
