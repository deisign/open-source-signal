<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ page.title }} — {{ config['site_title_en'] }}</title>
  <meta name="description" content="{{ page.meta_description }}">
  <meta name="robots" content="noindex">
  <link rel="canonical" href="{{ page_url }}">
  <meta property="og:title" content="{{ page.title }} — {{ config['site_title_en'] }}">
  <meta property="og:description" content="{{ page.meta_description }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ page_url }}">
  <meta property="og:image" content="{{ og_image_url }}">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="alternate" type="application/rss+xml" title="Open Source Signal RSS" href="{{ asset_prefix }}{{ config['rss_path'] }}">
  <link rel="icon" href="{{ asset_prefix }}static/logo-mark.png" type="image/png">
  <link rel="shortcut icon" href="{{ asset_prefix }}static/favicon.ico">
  {{ analytics_snippet | safe }}
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Arimo:wght@700;800&family=Fraunces:opsz,wght@9..144,850&family=Inter:wght@400;600;800&family=Source+Serif+4:opsz,wght@8..60,850&display=swap');
    :root { --display-latin: Fraunces, Georgia, serif; --display-cyr:'Source Serif 4', Georgia, serif; --label-font: Arimo, Arial, sans-serif; --paper:#F2EDDD; --ink:#141414; --muted:#6d665a; --line:rgba(20,20,20,.16); }
    * { box-sizing: border-box; }
    body { min-height:100vh; margin:0; color:var(--ink); background: radial-gradient(circle at 18% 18%, rgba(165,74,44,.18), transparent 24rem), radial-gradient(circle at 86% 12%, rgba(36,92,115,.18), transparent 24rem), linear-gradient(135deg,#f7f0df,#ece1c6 58%,#d9cfb7); font-family:Inter, system-ui, sans-serif; font-size:18px; line-height:1.55; display:flex; align-items:center; }
    .wrap { width:min(900px, calc(100% - 36px)); margin:0 auto; padding:56px 0; }
    .panel { border:1px solid var(--line); background:rgba(255,249,234,.78); border-radius:34px; padding:clamp(28px, 6vw, 58px); box-shadow:0 24px 70px rgba(20,20,20,.12); }
    .eyebrow, nav { font-family:var(--label-font); font-size:13px; font-weight:800; letter-spacing:.08em; text-transform:uppercase; color:var(--muted); }
    h1 { margin:18px 0 8px; font-family:var(--display-latin); font-size:clamp(64px, 13vw, 150px); line-height:.82; letter-spacing:-.075em; }
    .ua-title { margin:0 0 24px; font-family:var(--display-cyr); font-size:clamp(34px, 5vw, 68px); line-height:.95; letter-spacing:-.04em; font-weight:850; }
    p { max-width:72ch; }
    .cta { display:flex; flex-wrap:wrap; gap:12px; margin-top:30px; }
    a { color:inherit; text-decoration-thickness:.1em; text-underline-offset:.18em; }
    .cta a { background:#141414; color:#fff9ea; border-radius:999px; padding:10px 14px; text-decoration:none; font-family:var(--label-font); font-size:13px; font-weight:800; letter-spacing:.04em; text-transform:uppercase; }
    .trust-links { display:flex; flex-wrap:wrap; gap:14px; margin-top:34px; }
    .trust-links a { text-decoration:none; }
  </style>
</head>
<body>
  <main class="wrap">
    <article class="panel">
      <div class="eyebrow">{{ page.eyebrow }}</div>
      <h1>{{ page.title }}</h1>
      <p class="ua-title">{{ page.title_uk }}</p>
      <p><strong>{{ page.lead }}</strong></p>
      <p>{{ page.body_en }}</p>
      <p>{{ page.body_uk }}</p>
      <div class="cta">
        {% for link in page.cta_links %}
        <a href="{{ link.href }}">{{ link.label }}</a>
        {% endfor %}
      </div>
      <nav class="trust-links" aria-label="Trust and discovery pages">
        {% for link in trust_nav_links %}
        <a href="{{ asset_prefix }}{{ link.href }}">{{ link.label }}</a>
        {% endfor %}
      </nav>
    </article>
  </main>
</body>
</html>
