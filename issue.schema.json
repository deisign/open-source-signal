{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Open Source Signal issue",
  "type": "object",
  "required": [
    "issue_number",
    "date_iso",
    "date_label_en",
    "title_en",
    "title_uk",
    "slug",
    "items",
    "internal_notes"
  ],
  "properties": {
    "issue_number": {
      "type": "string"
    },
    "date_iso": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "slug": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    },
    "internal_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}