{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Open Source Signal Weekly Magazine issue",
  "type": "object",
  "required": [
    "issue_number",
    "week_start_iso",
    "week_end_iso",
    "date_label_en",
    "date_label_uk",
    "slug",
    "issue_type",
    "language_label",
    "title_en",
    "title_uk",
    "dek_en",
    "dek_uk",
    "editorial_note_en",
    "editorial_note_uk",
    "sections",
    "reading_list",
    "internal_notes"
  ],
  "properties": {
    "issue_number": {
      "type": "string"
    },
    "week_start_iso": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "week_end_iso": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "slug": {
      "type": "string"
    },
    "issue_type": {
      "const": "Weekly Magazine"
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    },
    "reading_list": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "internal_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
